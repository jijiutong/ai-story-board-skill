# AI 图片生成 API 密钥配置
# 复制此文件为 .env 并填入实际 key

# GPT Image (OpenAI DALL-E 3) - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# Flux (via Replicate) - https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxx

# Ideogram - https://ideogram.ai/manage-api
IDEOGRAM_API_KEY=xxxxxxxxxxxx

# 通义万相 (Alibaba Cloud DashScope) - https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxx

# Recraft - https://www.recraft.ai/api
RECRAFT_API_KEY=xxxxxxxxxxxx

# ComfyUI 本地地址（默认端口 8188）
COMFYUI_BASE_URL=http://127.0.0.1:8188
